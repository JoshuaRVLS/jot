{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc-vs2026",
      "displayName": "Windows MSVC x64 VS Solution",
      "description": "Generate a Visual Studio solution for the experimental native Windows target.",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/vs2026-x64",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/vs2026-x64",
        "JOT_TREESITTER": "OFF"
      }
    },
    {
      "name": "windows-msvc-vs2026-vcpkg",
      "displayName": "Windows MSVC x64 VS Solution (vcpkg)",
      "description": "Generate a Visual Studio solution using the vcpkg toolchain from VCPKG_ROOT.",
      "inherits": "windows-msvc-vs2026",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-vs2026-debug",
      "displayName": "Build Windows MSVC Debug",
      "configurePreset": "windows-msvc-vs2026",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-vs2026-release",
      "displayName": "Build Windows MSVC Release",
      "configurePreset": "windows-msvc-vs2026",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-vs2026-vcpkg-debug",
      "displayName": "Build Windows MSVC Debug (vcpkg)",
      "configurePreset": "windows-msvc-vs2026-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-vs2026-vcpkg-release",
      "displayName": "Build Windows MSVC Release (vcpkg)",
      "configurePreset": "windows-msvc-vs2026-vcpkg",
      "configuration": "Release"
    }
  ]
}
